def retrieve_context_for_column(
    field_name: str,
    table_name: str,
    search_client: SearchClient,
    top_k: int = 3,
) -> str:
    """
    Retrieve the most relevant professional descriptions from the index
    for a given column name + table context.

    Returns a formatted context string ready to inject into your GPT prompt.
    """
    query = f"{field_name} {table_name}"

    results = list(search_client.search(
        search_text=query,
        query_type=QueryType.SEMANTIC,
        semantic_configuration_name="commerce-semantic",
        top=top_k,
        select=["field_name", "professional_description", "constraints",
                "related_fields", "compliance_notes", "domain"],
    ))

    if not results:
        return ""

    context_parts = []
    for r in results:
        context_parts.append(
            f"Field: {r['field_name']} [{r['domain']}]\n"
            f"Description: {r['professional_description']}\n"
            f"Constraints: {r['constraints']}\n"
            f"Related: {r['related_fields']}"
        )
    return "\n\n---\n\n".join(context_parts)


