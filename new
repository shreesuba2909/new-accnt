# STEP 3 — UPLOAD DOCUMENTS
# ══════════════════════════════════════════════════════════════════════════════

def upload_documents(search_client: SearchClient, documents: list[dict], batch_size: int = 50) -> None:
    """
    Upload documents to the index in batches with retry logic.
    """
    log.info("━━ Step 3: Uploading %d documents (batch_size=%d) ━━", len(documents), batch_size)
    total_uploaded = 0

    for i in range(0, len(documents), batch_size):
        batch = documents[i : i + batch_size]
        attempt = 0
        while attempt < 3:
            try:
                result = search_client.upload_documents(documents=batch)
                failed = [r for r in result if not r.succeeded]
                if failed:
                    log.warning("  ⚠  %d documents failed in batch %d", len(failed), i // batch_size + 1)
                    for f in failed:
                        log.warning("     key=%s  error=%s", f.key, f.error_message)
                total_uploaded += len(batch) - len(failed)
                break
            except HttpResponseError as exc:
                attempt += 1
                log.warning("  Batch %d upload failed (attempt %d/3): %s", i // batch_size + 1, attempt, exc.message)
                time.sleep(2 ** attempt)

    log.info("  ✓ %d / %d documents uploaded successfully", total_uploaded, len(documents))


